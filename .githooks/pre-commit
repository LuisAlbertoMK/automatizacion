#!/usr/bin/env bash
# Pre-commit hook: secrets scan + ruff + pytest quick
# Instalar: git config core.hooksPath .githooks

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

FAILED=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}[pre-commit] No staged files to check${NC}"
    exit 0
fi

# ═══════════════════════════════════════════════════════════════
# 1. Secrets scan
# ═══════════════════════════════════════════════════════════════
echo -e "${YELLOW}[pre-commit] 1/5 🔍 Escaneando secrets...${NC}"

SECRET_PATTERNS=(
    'CAPTCHA_API_KEY=.'
    'IMAP_PASSWORD=.'
    'STORAGE_KEY=.'
    '-----BEGIN\s+(RSA|EC|OPENSSH)\s+PRIVATE\s+KEY-----'
    'ghp_[A-Za-z0-9]{36}'
    'gho_[A-Za-z0-9]{36}'
    'sk-[A-Za-z0-9]{32,}'
    'AIza[0-9A-Za-z_-]{35}'
)

for pattern in "${SECRET_PATTERNS[@]}"; do
    MATCHES=$(echo "$STAGED_FILES" | xargs git show :./ 2>/dev/null | grep -n -e "$pattern" || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}[pre-commit] ❌ Posible secret encontrado:${NC}"
        echo "$MATCHES" | head -5
        FAILED=1
    fi
done

# ═══════════════════════════════════════════════════════════════
# 2. Debug statements (pdb, breakpoint, print)
# ═══════════════════════════════════════════════════════════════
echo -e "${YELLOW}[pre-commit] 2/5 🔍 Escaneando debug statements...${NC}"

for pattern in 'import pdb' 'breakpoint()' 'pdb.set_trace()'; do
    MATCHES=$(echo "$STAGED_FILES" | xargs git show :./ 2>/dev/null | grep -n -e "$pattern" || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${YELLOW}[pre-commit] ⚠ Debug statement encontrado:${NC}"
        echo "$MATCHES" | head -3
    fi
done

# ═══════════════════════════════════════════════════════════════
# 3. Large files (>1MB)
# ═══════════════════════════════════════════════════════════════
echo -e "${YELLOW}[pre-commit] 3/5 📏 Verificando tamaño de archivos...${NC}"

for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        SIZE=$(git show :"$file" 2>/dev/null | wc -c)
        if [ "$SIZE" -gt 1048576 ]; then
            echo -e "${RED}[pre-commit] ❌ Archivo >1MB: $file (${SIZE} bytes)${NC}"
            FAILED=1
        fi
    fi
done

# ═══════════════════════════════════════════════════════════════
# 4. Ruff linting on staged Python files
# ═══════════════════════════════════════════════════════════════
PY_FILES=$(echo "$STAGED_FILES" | grep '\.py$' || true)
if [ -n "$PY_FILES" ]; then
    echo -e "${YELLOW}[pre-commit] 4/5 🐍 Ruff linting...${NC}"
    # Show the staged content to ruff via stdin (not the working tree)
    FAILED_ANY=0
    for f in $PY_FILES; do
        if git show :"$f" 2>/dev/null | python -m ruff check --stdin-filename "$f" - 2>&1; then
            :
        else
            FAILED_ANY=1
        fi
    done
    if [ "$FAILED_ANY" -eq 1 ]; then
        echo -e "${RED}[pre-commit] ❌ Ruff encontró errores (corregilos con 'ruff check --fix')${NC}"
        FAILED=1
    else
        echo -e "${GREEN}[pre-commit] ✅ Ruff OK${NC}"
    fi
else
    echo -e "${CYAN}[pre-commit] 4/5 🐍 Sin archivos Python, saltando ruff${NC}"
fi

# ═══════════════════════════════════════════════════════════════
# 5. Quick pytest on tests/ if any Python file changed
# ═══════════════════════════════════════════════════════════════
if [ -n "$PY_FILES" ]; then
    echo -e "${YELLOW}[pre-commit] 5/5 🧪 Quick pytest (tests/)...${NC}"
    if python -m pytest tests/ -q --tb=line -x 2>&1; then
        echo -e "${GREEN}[pre-commit] ✅ Tests OK${NC}"
    else
        echo -e "${RED}[pre-commit] ❌ Tests fallaron. Corregí antes de commitear.${NC}"
        FAILED=1
    fi
else
    echo -e "${CYAN}[pre-commit] 5/5 🧪 Sin cambios Python, saltando pytest${NC}"
fi

# ═══════════════════════════════════════════════════════════════
# Result
# ═══════════════════════════════════════════════════════════════
if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}[pre-commit] ❌ Pre-commit FAILED. Corregí los errores antes de commitear.${NC}"
    exit 1
fi

echo -e "${GREEN}[pre-commit] ✅ Todos los checks pasaron${NC}"
exit 0
