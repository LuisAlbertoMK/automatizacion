#!/usr/bin/env bash
# Pre-commit hook: secrets scan + basic validation
# Instalar: git config core.hooksPath .githooks

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

FAILED=0

# ── 1. Secrets scan ───────────────────────────────────────────────
echo -e "${YELLOW}[pre-commit] 🔍 Escaneando secrets...${NC}"

# Patrones de riesgo
SECRET_PATTERNS=(
    'CAPTCHA_API_KEY=.'
    'IMAP_PASSWORD=.'
    'STORAGE_KEY=.'
    '-----BEGIN\s+(RSA|EC|OPENSSH)\s+PRIVATE\s+KEY-----'
    'ghp_[A-Za-z0-9]{36}'
    'gho_[A-Za-z0-9]{36}'
    'sk-[A-Za-z0-9]{32,}'
    'AIza[0-9A-Za-z_-]{35}'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}[pre-commit] No staged files to check${NC}"
    exit 0
fi

for pattern in "${SECRET_PATTERNS[@]}"; do
    MATCHES=$(echo "$STAGED_FILES" | xargs git show :./ 2>/dev/null | grep -n -e "$pattern" || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}[pre-commit] ❌ Posible secret encontrado:${NC}"
        echo "$MATCHES" | head -5
        FAILED=1
    fi
done

# ── 2. Check for debug print / pdb / breakpoint ──────────────────
echo -e "${YELLOW}[pre-commit] 🔍 Escaneando debug statements...${NC}"

for pattern in 'import pdb' 'breakpoint()' 'pdb.set_trace()'; do
    MATCHES=$(echo "$STAGED_FILES" | xargs git show :./ 2>/dev/null | grep -n -e "$pattern" || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${YELLOW}[pre-commit] ⚠ Debug statement encontrado:${NC}"
        echo "$MATCHES" | head -3
    fi
done

# ── 3. Check for large files (>1MB) ──────────────────────────────
echo -e "${YELLOW}[pre-commit] 📏 Verificando tamaño de archivos...${NC}"

for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        SIZE=$(git show :"$file" 2>/dev/null | wc -c)
        if [ "$SIZE" -gt 1048576 ]; then
            echo -e "${RED}[pre-commit] ❌ Archivo >1MB: $file (${SIZE} bytes)${NC}"
            FAILED=1
        fi
    fi
done

# ── Result ───────────────────────────────────────────────────────
if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}[pre-commit] ❌ Pre-commit FAILED. Corregí los errores antes de commitear.${NC}"
    exit 1
fi

echo -e "${GREEN}[pre-commit] ✅ Todos los checks pasaron${NC}"
exit 0
