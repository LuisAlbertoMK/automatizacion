# ═══════════════════════════════════════════════════════════
#  Configuración del Agente de Trámites GOB.MX
#  Copiá este archivo como config.env y editá los valores
# ═══════════════════════════════════════════════════════════

# ─── 2captcha ──────────────────────────────────────────────
# Registrate en https://2captcha.com, cargá crédito (~$2 USD)
CAPTCHA_API_KEY=tu_api_key_aqui

# ─── Correo IMAP (para NSS IMSS automático) ────────────────
# Usá contraseña de aplicación, no la normal
IMAP_EMAIL=tucorreo@gmail.com
IMAP_PASSWORD=tu_contrasena_de_aplicacion
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# ─── Configuración general ─────────────────────────────────
OUTPUT_DIR=./output
TIMEOUT=60
HEADLESS=true

# Clave para encriptar perfiles (generá una nueva!)
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STORAGE_KEY=cambia_esta_clave_secreta_32chars!

# ─── Rate limiting ─────────────────────────────────────────
# Segundos mínimos entre requests a portales (protege tu IP)
REQUEST_DELAY=2.0

# ─── reCAPTCHA ─────────────────────────────────────────────
# true = 2captcha resuelve automáticamente (consume crédito)
# false = modo manual (resolvelo en el navegador)
RECAPTCHA_AUTO=false

# ─── Logging ───────────────────────────────────────────────
LOG_DIR=./logs
# true = logs detallados (debug)
VERBOSE=false
