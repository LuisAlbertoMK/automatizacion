# ─── 2captcha ─────────────────────────────────────────────
# Regístrate en https://2captcha.com — carga $2 USD y obtén tu API key
CAPTCHA_API_KEY=tu_api_key_aqui

# ─── Correo para recibir verificaciones del IMSS ──────────
# Usa un correo Gmail o Outlook. Necesitas activar IMAP en la config.
IMAP_EMAIL=tucorreo@gmail.com
IMAP_PASSWORD=tu_contrasena_de_aplicacion
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# ─── Configuración general ────────────────────────────────
# Carpeta donde se guardan los PDFs descargados
OUTPUT_DIR=./output

# Tiempo máximo de espera por operación (segundos)
TIMEOUT=60

# Mostrar navegador durante el proceso (true = visible, false = oculto)
# Recomendado: false en producción, true para depurar
HEADLESS=true

# Clave para encriptar perfiles guardados (cambia esto)
STORAGE_KEY=cambia_esta_clave_secreta_32chars!
