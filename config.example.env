# ============================================================================
#  Configuracion del Agente de Tramites GOB.MX
#  Copia este archivo como config.env y edita los valores
# ============================================================================
#
#  IMPORTANTE: Los secrets sensibles se pueden guardar en
#  Windows Credential Manager en vez de este archivo.
#
#  Para migrar:
#      python -c "from utils.secrets_manager import store_all; store_all()"
#
#  Esto guarda CAPTCHA_API_KEY, IMAP_*, STORAGE_KEY y ANTHROPIC_API_KEY
#  en el Credential Manager. Despues podes borrar los valores reales
#  de config.env y el sistema los va a buscar ahi primero.
#
#  Si no usas Credential Manager, funciona exactamente como antes
#  (lee directo de config.env).
# ============================================================================

# --- 2captcha ----------------------------------------------------------------
# Registrate en https://2captcha.com, carga credito (~$2 USD)
CAPTCHA_API_KEY=tu_api_key_aqui

# --- Correo IMAP (para NSS IMSS automatico) ----------------------------------
# Usa contrasena de aplicacion, no la normal
IMAP_EMAIL=tucorreo@gmail.com
IMAP_PASSWORD=tu_contrasena_de_aplicacion
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# --- Configuracion general ----------------------------------------------------
OUTPUT_DIR=./output
TIMEOUT=60
HEADLESS=true

# Clave para encriptar perfiles (genera una nueva!)
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STORAGE_KEY=cambia_esta_clave_secreta_32chars!

# --- Rate limiting ------------------------------------------------------------
# Segundos minimos entre requests a portales (protege tu IP)
REQUEST_DELAY=2.0

# --- reCAPTCHA ----------------------------------------------------------------
# true = 2captcha resuelve automaticamente (consume credito)
# false = modo manual (resolvelo en el navegador)
RECAPTCHA_AUTO=false

# --- Logging ------------------------------------------------------------------
LOG_DIR=./logs
# true = logs detallados (debug)
VERBOSE=false
